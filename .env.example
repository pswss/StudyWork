# Remap 로컬 서버 환경설정
# cp .env.example .env  후 값을 채우세요.

# 선택: 첫 계정 생성 전의 기존 비밀번호 로그인 호환용(10자·10바이트 이상).
# 첫 계정 가입에는 필요하지 않고, 가입 뒤에는 인증에 사용되지 않습니다.
APP_PASSWORD=

# 세션 토큰 서명 키(UTF-8 32바이트 이상). 예: openssl rand -base64 32
AUTH_SECRET=

# true면 127.0.0.1에만 바인딩하고 신뢰한 루프백 HTTPS 프록시 외의 API 요청을 거부합니다.
# Tailscale Serve 등 HTTPS reverse proxy를 실제로 구성한 뒤에만 켜세요.
STUDYWORK_HTTPS_ONLY=false

# 서버 포트 (기본 8787)
PORT=8787

# 데이터 저장 위치 (SQLite DB + 업로드 파일)
DATA_DIR=./data

# AI provider. 기본값은 저장된 ChatGPT 로그인을 쓰는 로컬 codex CLI입니다.
STUDYWORK_AI_PROVIDER=codex-cli

# launchd PATH에 codex가 없을 때만 절대 경로를 지정합니다(선택).
STUDYWORK_CODEX_BIN=

# 최초 실행 호환 fallback. 이후 값은 앱의 설정 탭에서 저장하며 DB 설정이 우선합니다.
STUDYWORK_AI_MODEL=gpt-5.6-sol
STUDYWORK_AI_REASONING_EFFORT=high

# 로컬 Codex 호출 보호 설정(선택). 아래 값은 현재 코드 기본값입니다.
STUDYWORK_AI_TIMEOUT_MS=300000
STUDYWORK_AI_MAX_CONCURRENCY=4

# Obsidian 볼트 절대 경로 (선택). 공백·한글 경로를 그대로 입력할 수 있습니다.
OBSIDIAN_VAULT_PATH=

# 기본 false: 내보내기 비활성. 실제 볼트에 새 노트를 만들 때만 true.
OBSIDIAN_WRITE_ENABLED=false

# 추가 Skill 루트(선택). macOS/Linux에서는 콜론(:)으로 여러 절대 경로를 구분합니다.
# 비우면 사용자 전역 ~/.codex/skills를 검색합니다.
STUDYWORK_SKILLS_DIRS=

# Remap AI 요청에 실제 주입할 Skill 이름(쉼표 구분). 비우면 아래 두 범용 Skill을 사용합니다.
STUDYWORK_ENABLED_SKILLS=learning-material-analysis,grounded-study-notes
